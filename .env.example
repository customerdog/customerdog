# ──────────────────────────────────────────────────────────────────────
# customerdog — environment template
#
# Copy to .env.local for dev, set in your hosting provider for prod.
# All vars are checked at first use via src/lib/env.ts (fail-fast).
# Run `npm run check` to live-probe everything.
# ──────────────────────────────────────────────────────────────────────

# Where this app is reachable. Used to construct webhook URLs we hand
# to qlaud at tool-registration time.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── qlaud ─────────────────────────────────────────────────────────────
# Single key for all chat + admin operations. Get one at
# qlaud.ai/keys with "admin" scope (admin scope is required to
# register tools; standard scope works fine for chat alone if you split
# the keys later).
QLAUD_BASE_URL=https://api.qlaud.ai
QLAUD_KEY=qlk_live_…

# Per-tool HMAC secrets — populated by `npm run register-tools` after
# the first deploy. Each verifies the HMAC signature on inbound tool
# webhook deliveries. Optional at boot.
QLAUD_TOOL_SECRET_CREATE_TICKET=wsk_…
QLAUD_TOOL_SECRET_SEND_EMAIL=wsk_…

# ─── Supabase ──────────────────────────────────────────────────────────
# 1. Create a free project at supabase.com (no card needed).
# 2. SQL Editor → paste supabase/schema.sql → Run.
# 3. Top of any project page → click "Connect" → copy the project URL.
# 4. Sidebar → Settings (gear) → API Keys. Two tabs:
#      • "Publishable and secret API keys" — copy the SECRET key
#        (sb_secret_…). The newer recommended format.
#      • "Legacy anon, service_role API keys" — copy the service_role
#        SECRET (eyJ…). Older but still works.
#    Either key works here. NOT the Publishable / anon key — that's
#    gated by Row-Level Security and our schema doesn't ship policies.
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ…

# ─── Admin gate ────────────────────────────────────────────────────────
# A single shared password gates /admin/*. Set both vars before deploy;
# the admin signs in once and gets a 30-day signed-cookie session.
# Generate strong values:  openssl rand -base64 32
ADMIN_PASSWORD=set-a-long-random-password
ADMIN_COOKIE_SECRET=set-a-long-random-secret

# ─── Optional integrations ─────────────────────────────────────────────
# Set whichever your /admin/settings configuration selects. The chat
# refuses to escalate via a destination whose secrets are missing.

# Resend — for the send_email_to_user tool, and for
# ticket_destination='email' if you choose it.
RESEND_API_KEY=re_…

# Email destination (where tickets go when ticket_destination='email')
TICKET_EMAIL_TO=support@yourcompany.com

# Slack destination
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T0000000/B0000000/xxxxxxxxxxxxxxxxxxxxxxxx

# Linear destination
LINEAR_API_KEY=lin_api_…
LINEAR_TEAM_ID=…

# Zendesk destination
ZENDESK_SUBDOMAIN=yourcompany
ZENDESK_EMAIL=support-bot@yourcompany.com
ZENDESK_API_TOKEN=…
