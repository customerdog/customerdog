# ──────────────────────────────────────────────────────────────────────
# customerdog — environment template
#
# Copy to .env.local for dev, set in your hosting provider for prod.
# All vars are checked at first use via src/lib/env.ts (fail-fast).
# Run `npm run check` to live-probe everything.
# ──────────────────────────────────────────────────────────────────────

# Where this app is reachable. Used to construct webhook URLs we hand
# to qlaud at tool-registration time.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Clerk ──────────────────────────────────────────────────────────────
# Currently still used by the chat routes (legacy chatai pattern).
# Commit 3 of the rewrite removes Clerk entirely; until then, keep these.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_…
CLERK_SECRET_KEY=sk_test_…
CLERK_WEBHOOK_SECRET=whsec_…

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── qlaud ─────────────────────────────────────────────────────────────
# Defaults to https://api.qlaud.ai if unset.
QLAUD_BASE_URL=https://api.qlaud.ai

# Master key (qlk_live_…) from console.qlaud.ai/keys. Used server-side
# for /v1/keys (mint per-user keys) and /v1/tools (register tools).
QLAUD_MASTER_KEY=qlk_live_…

# Per-tool secrets — populated by `npm run register-tools` after the
# first deploy. Each one verifies the HMAC signature on inbound tool
# webhook deliveries.
QLAUD_TOOL_SECRET_WEB_SEARCH=wsk_…
QLAUD_TOOL_SECRET_GENERATE_IMAGE=wsk_…

# ─── Supabase ──────────────────────────────────────────────────────────
# 1. Create a free project at supabase.com (no card needed).
# 2. Project Settings → API: copy the URL + service_role key here.
# 3. SQL Editor → paste supabase/schema.sql → Run.
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ…

# ─── Admin gate ────────────────────────────────────────────────────────
# A single shared password gates /admin/*. Set both vars before deploy;
# the admin signs in once and gets a 30-day signed-cookie session.
# Generate strong values:  openssl rand -base64 32
ADMIN_PASSWORD=set-a-long-random-password
ADMIN_COOKIE_SECRET=set-a-long-random-secret

# ─── Onboarding ────────────────────────────────────────────────────────
# Hard spend cap minted on each new per-user qlaud key. (Legacy chatai
# pattern. Removed in commit 3 when chat goes anonymous.)
NEW_USER_BUDGET_USD=5
