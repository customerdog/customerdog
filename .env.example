# ──────────────────────────────────────────────────────────────────────
# customerdog — environment template
#
# Copy to .env.local for dev, set in your hosting provider for prod.
# All vars are checked at first use via src/lib/env.ts (fail-fast).
# Run `npm run check` to live-probe everything.
# ──────────────────────────────────────────────────────────────────────

# Where this app is reachable. Visitors see it; the embed widget script
# is hosted from this origin too.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── qlaud ─────────────────────────────────────────────────────────────
# Single key for chat. Get one at qlaud.ai/keys. Tool actions
# (send email, file ticket, lookup customer, etc.) live entirely in
# qlaud — enable any built-in or MCP connector at qlaud.ai/tools and
# tenant-share it. customerdog itself doesn't ship tool handlers.
QLAUD_BASE_URL=https://api.qlaud.ai
QLAUD_KEY=qlk_live_…

# ─── Supabase ──────────────────────────────────────────────────────────
# 1. Create a free project at supabase.com (no card needed).
# 2. Top of any project page → click "Connect" → copy the project URL.
# 3. Sidebar → Settings (gear) → API Keys. Two tabs:
#      • "Publishable and secret API keys" — copy the SECRET key
#        (sb_secret_…). The newer recommended format.
#      • "Legacy anon, service_role API keys" — copy the service_role
#        SECRET (eyJ…). Older but still works.
#    Either key works here. NOT the Publishable / anon key — that's
#    gated by Row-Level Security and our schema doesn't ship policies.
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ…

# Direct Postgres connection string. Used to auto-run supabase/schema.sql
# on first admin page load — no manual SQL Editor step needed.
#
# Get it from: Supabase → Settings → Database → Connection string →
# "Session pooler" tab (port 5432). Use Session, NOT Transaction —
# Transaction pooler can reject multi-statement DDL like our schema.sql.
# We only use this connection during migrations (rare event), so the
# longer-lived connections of session mode are fine.
#
# Don't worry about wiping data: the migration only runs when our
# tables are genuinely missing (verified via information_schema), and
# schema.sql is idempotent regardless.
DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── Admin gate ────────────────────────────────────────────────────────
# A single shared password gates /admin/*. Set both vars before deploy;
# the admin signs in once and gets a 30-day signed-cookie session.
# Generate strong values:  openssl rand -base64 32
ADMIN_PASSWORD=set-a-long-random-password
ADMIN_COOKIE_SECRET=set-a-long-random-secret

# ─── Optional ──────────────────────────────────────────────────────────

# Firecrawl — when set, KB ingestion routes URL fetches through
# Firecrawl's /v1/scrape endpoint, which renders pages in a real
# browser server-side. Use this if your sources are client-rendered
# SPAs that the native fetch+Readability path can't see into.
# Without it, customerdog handles SSR/SSG pages just fine — which is
# most docs + marketing sites. Free tier covers 500 page-credits.
FIRECRAWL_API_KEY=fc-…
