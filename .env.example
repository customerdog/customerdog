# ──────────────────────────────────────────────────────────────────────
# customerdog — environment template
#
# Copy to .env.local for dev, set in your hosting provider for prod.
# All vars are checked at first use via src/lib/env.ts (fail-fast).
# Run `npm run check` to live-probe everything.
# ──────────────────────────────────────────────────────────────────────

# Where this app is reachable. Used to construct webhook URLs we hand
# to qlaud at tool-registration time.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Clerk ──────────────────────────────────────────────────────────────
# From dashboard.clerk.com → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_…
CLERK_SECRET_KEY=sk_test_…

# From dashboard.clerk.com → Webhooks → Add Endpoint pointing at
# {NEXT_PUBLIC_APP_URL}/api/webhooks/clerk subscribed to user.created.
CLERK_WEBHOOK_SECRET=whsec_…

# Optional: where Clerk sends users after sign-in/up. Defaults are fine.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── qlaud ─────────────────────────────────────────────────────────────
# Defaults to https://api.qlaud.ai if unset.
QLAUD_BASE_URL=https://api.qlaud.ai

# Master key (qlk_live_…) from console.qlaud.ai/keys. Used server-side
# for /v1/keys (mint per-user keys) and /v1/tools (register tools).
# Per-user keys are minted at signup and stashed in Clerk privateMetadata.
QLAUD_MASTER_KEY=qlk_live_…

# Per-tool secrets — populated by `npm run register-tools` after the
# first deploy. Each one verifies the HMAC signature on inbound tool
# webhook deliveries.
QLAUD_TOOL_SECRET_WEB_SEARCH=wsk_…
QLAUD_TOOL_SECRET_GENERATE_IMAGE=wsk_…

# ─── Onboarding ────────────────────────────────────────────────────────
# Hard spend cap minted on each new per-user qlaud key. $5 covers a few
# hundred Sonnet messages — generous enough to feel real, tight enough
# to keep your bill predictable if a key leaks.
NEW_USER_BUDGET_USD=5
