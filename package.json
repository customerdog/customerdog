    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "server-only": "^0.0.1",
    "shiki": "^1.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^21.1.0",
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
